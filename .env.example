NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Authentication is required by default. Local setup writes development values to .env.local.
REQUIRE_SUPABASE_AUTH=true
ENABLE_LOCAL_LOGIN=false
NEXT_PUBLIC_ENABLE_LOCAL_LOGIN=false
LOCAL_LOGIN_EMAIL=
LOCAL_LOGIN_PASSWORD=
APP_URL=http://localhost:3000
NOTION_DECISION_LOG_TOKEN=
NOTION_DECISION_LOG_DATA_SOURCE_ID=
GITHUB_SYNC_OWNER=findmydoc-platform
GITHUB_SYNC_REPO=management
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
# Alternative to GITHUB_APP_PRIVATE_KEY:
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=
GITHUB_TOKEN_ENCRYPTION_KEY=
GOOGLE_CHAT_WEBHOOK_URL=
GOOGLE_CHAT_SERVICE_ACCOUNT_EMAIL=
GOOGLE_CHAT_PRIVATE_KEY=
GOOGLE_CHAT_DELIVERY_ENABLED=false
FOUNDEROPS_DELIVERY_SECRET=
FOUNDEROPS_MAINTENANCE_SECRET=
# Production Google Chat delivery:
# APP_URL=https://founder-ops.findmydoc.eu
# GOOGLE_CHAT_DELIVERY_ENABLED=true
# Operational delivery endpoint, separate from the release chat workflow:
# POST https://founder-ops.findmydoc.eu/api/notifications/deliver
# x-founderops-delivery-secret: <FOUNDEROPS_DELIVERY_SECRET>
# Scheduled planning trash maintenance uses a separate production-only secret.
