{
  "name": "fmd-planning",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "next dev",
    "test": "node --test tests/*.test.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "audit:stewardship": "node scripts/code-stewardship-audit.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "verify:auth": "node scripts/verify-auth.mjs",
    "verify:operational": "node scripts/verify-operational.mjs",
    "verify:vercel-ready": "node scripts/verify-vercel-ready.mjs",
    "verify:hierarchy": "node scripts/verify-hierarchy.mjs",
    "verify:github-sync": "node scripts/verify-github-sync.mjs",
    "verify:google-chat": "node scripts/verify-google-chat-rollout.mjs",
    "verify:task-utf8": "node scripts/verify-task-utf8.mjs",
    "verify:release": "node --test tests/*.test.mjs && node scripts/verify-task-utf8.mjs && eslint && node scripts/verify-vercel-ready.mjs && node scripts/verify-google-chat-rollout.mjs && pnpm audit --audit-level=moderate",
    "verify:deploy": "pnpm test && pnpm run verify:vercel-ready && pnpm run verify:google-chat && pnpm run lint",
    "vercel:build": "pnpm run verify:deploy && pnpm run build",
    "deploy:supabase-schema": "node scripts/deploy-production-schema.mjs",
    "plan:github-linking": "node scripts/plan-github-issue-linking.mjs",
    "migrate:relationships": "node scripts/migrate-task-relationships.mjs",
    "apply:sql": "node scripts/apply-sql.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.1",
    "driver.js": "^1.6.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "pg": "^8.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
